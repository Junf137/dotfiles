#!/bin/bash

# Inspired by: https://github.com/junegunn/fzf/blob/master/ADVANCED.md#dynamic-reloading-of-the-list

# Usage: kill_ps [signal]
# Interactively select and kill processes by name or PID.
# If a signal is provided, it will be sent to the selected processes.
# If no signal is provided, SIGTERM will be sent by default.

kill_ps() {
    local signal="TERM"
    local force=false

    while [ $# -gt 0 ]; do
        case "$1" in
        --help|-h)
            echo "Usage: kill_ps [signal]"
            echo "Interactively select and kill processes by name or PID."
            echo "If a signal is provided, it will be sent to the selected processes."
            echo "If no signal is provided, SIGTERM will be sent by default."
            echo "Use --force to allow SIGKILL/9."
            return
            ;;
        --force)
            force=true
            ;;
        --signal)
            shift
            signal="${1:-}"
            ;;
        *)
            signal="$1"
            ;;
        esac
        shift
    done

    signal="${signal#SIG}"
    if [ -z "$signal" ] || ! kill -l "$signal" >/dev/null 2>&1; then
        echo "Error: invalid signal: $signal" >&2
        return 1
    fi

    if { [ "$signal" = "9" ] || [ "$signal" = "KILL" ]; } && ! $force; then
        echo "Error: SIGKILL requires --force." >&2
        return 1
    fi

    # Check if fzf-tmux is installed
    if ! command -v fzf-tmux &>/dev/null; then
        echo "Error: fzf-tmux is not installed. Please install fzf-tmux to use this script."
        return 1
    fi

    # CTRL-Y copies the selected line(s) (PID, PPID, CMD, ...) to the clipboard.
    # {+} covers marked selections, or the current line if none is marked. The work is
    # delegated to the sibling `clip` helper, which picks a transport that reaches the
    # terminal you are actually sitting at (tmux/OSC 52 over SSH, a native tool when
    # local) and never hangs the way wl-copy/xclip do when no display is reachable.
    # Resolve `clip` next to this script (portable: no `readlink -f`, which BSD/macOS
    # lacks). Falls back to the PATH copy (utils/ is on PATH) if the sibling is absent.
    local clip_bin
    clip_bin="$(cd "$(dirname "${BASH_SOURCE[0]}")" 2>/dev/null && pwd)/clip"
    [ -x "$clip_bin" ] || clip_bin="clip"

    local copy_bind=(--bind="ctrl-y:execute-silent(printf '%s\n' {+} | '$clip_bin')")
    local copy_hint=", CTRL-Y to copy"

    # Get PID interactively using fzf
    local pid

    # fzf-tmux --multi: pipes the output of ps -ef into fzf, which allows the user to interactively select one or more processes.
    #   --header-lines=2 is used to disallow selecting the first two lines of the output (i.e., the header).
    #   --preview part simply prints the selected line in case it is too long to fit selection window.
    # awk '{print $2}': extracts the second column (PID) from the output of fzf and assigns it to the pid variable.
    pid=$((date; ps -ef) | \
        fzf-tmux --multi -p 80%,70% \
            --header="Press CTRL-R to reload${copy_hint}"$'\n' --header-lines=2 \
            --preview='echo {}' --preview-window=down,3,wrap \
            --bind='ctrl-r:reload(date; ps -ef)' \
            --bind='ctrl-/:toggle-preview' \
            "${copy_bind[@]}" | \
        awk '{print $2}')

    # Check if a PID is selected
    if [ -n "$pid" ]; then
        # Remove leading and trailing whitespace
        pid="${pid#"${pid%%[![:space:]]*}"}"
        pid="${pid%"${pid##*[![:space:]]}"}"

        # Kill selected processes
        echo "Killing processes with SIG$signal: $pid"

        # echo "$pid": This command prints the PID(s) of the selected process(es).
        # | xargs: This command passes the output of echo (i.e., the PID(s)) as arguments to the kill command.
        printf '%s\n' "$pid" | xargs kill -s "$signal"
    else
        echo "No processes selected."
    fi
}

# Call the main function
kill_ps "$@"
