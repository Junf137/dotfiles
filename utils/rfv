#!/bin/bash

# Inspired by: https://github.com/junegunn/fzf/blob/master/ADVANCED.md#switching-between-ripgrep-mode-and-fzf-mode-using-a-single-key-binding

# Usage: rfv [query]
# 1. Search for text in files using Ripgrep.
# 2. Interactively restart Ripgrep with reload action.
# 3. Open the file in Vim.

rfv() {
    # Check if the first argument is --help or -h
    case "$1" in
        --help|-h)
            echo "Usage: rfv [query]"
            echo "1. Search for text in files using Ripgrep."
            echo "2. Interactively restart Ripgrep with reload action."
            echo "3. Open the file in Vim."
            exit 0
            ;;
    esac

    # Check if fzf is installed
    if ! command -v fzf &>/dev/null; then
        echo "Error: fzf is not installed. Please install fzf to use this script."
        return 1
    fi
    if ! command -v rg &>/dev/null; then
        echo "Error: rg is not installed. Please install ripgrep to use this script."
        return 1
    fi

    local tmp_dir tmp_r tmp_f preview_cmd editor
    tmp_dir="$(mktemp -d "${TMPDIR:-/tmp}/rg-fzf.XXXXXX")" || return 1
    tmp_r="$tmp_dir/ripgrep-query"
    tmp_f="$tmp_dir/fzf-query"
    trap 'rm -rf "$tmp_dir"' INT TERM EXIT

    # This cannot be executed with fzf-tmux since we need to open a vim session
    # Switch between Ripgrep mode and fzf filtering mode (CTRL-T)
    RG_PREFIX="rg --column --line-number --no-heading --color=always --smart-case -- "
    INITIAL_QUERY="${*:-}"

    if command -v bat &>/dev/null; then
        preview_cmd='bat --color=always {1} --highlight-line {2}'
    else
        preview_cmd='sed -n "1,200p" {1}'
    fi
    editor="${EDITOR:-vim}"

    : | fzf --ansi --disabled --query "$INITIAL_QUERY" \
        --bind "start:reload:$RG_PREFIX {q}" \
        --bind "change:reload:sleep 0.1; $RG_PREFIX {q} || true" \
        --bind 'ctrl-t:transform:[[ ! $FZF_PROMPT =~ ripgrep ]] &&
        echo "rebind(change)+change-prompt(1. ripgrep> )+disable-search+transform-query:echo \{q} > '"$tmp_f"'; cat '"$tmp_r"'" ||
        echo "unbind(change)+change-prompt(2. fzf> )+enable-search+transform-query:echo \{q} > '"$tmp_r"'; cat '"$tmp_f"'"' \
        --color "hl:-1:underline,hl+:-1:underline:reverse" \
        --prompt '1. ripgrep> ' \
        --delimiter : \
        --header 'CTRL-T: Switch between ripgrep/fzf' \
        --preview "$preview_cmd" \
        --preview-window 'up,60%,border-bottom,+{2}+3/3,~3' \
        --bind "enter:become($editor {1} +{2})"
    local status=$?
    rm -rf "$tmp_dir"
    trap - INT TERM EXIT
    return "$status"
}

# Call the function
rfv "$@"
