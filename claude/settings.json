{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(wc:*)",
      "Bash(tree:*)",
      "Bash(find:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(cat:*)",
      "Bash(sort:*)",
      "Bash(awk:*)",
      "Bash(xargs ls:*)",
      "Bash(grep:*)",
      "Bash(du:*)",
      "Bash(file:*)",
      "Bash(stat:*)",
      "Bash(readlink:*)",
      "Bash(ffprobe:*)",
      "Bash(identify:*)",
      "Bash(lscpu:*)",
      "Bash(nvidia-smi:*)",
      "Bash(chmod:*)",
      "Bash(ln:*)",
      "Bash(bash -n:*)",
      "Bash(python -m py_compile:*)",
      "Bash(python -c:*)",
      "Bash(conda activate:*)",
      "Bash(*/conda run:*)",
      "Bash(*/conda env:*)",
      "Bash(*/conda list:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git branch:*)",
      "Bash(git log:*)",
      "Bash(git status:*)",
      "Bash(git checkout:*)",
      "Bash(git diff:*)",
      "Bash(git mv:*)",
      "Bash(git rm:*)",
      "Bash(git submodule:*)",
      "Bash(git stash:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(git reset:*)",
      "Bash(git restore:*)",
      "Bash(git rebase:*)"
    ],
    "defaultMode": "default"
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "printf '\\a' > /dev/tty"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash /home/junf/.claude/statusline-command.sh"
  },
  "effortLevel": "xhigh",
  "voiceEnabled": true,
  "skipDangerousModePermissionPrompt": true
}
